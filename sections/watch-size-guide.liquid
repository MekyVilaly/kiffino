{{ 'watch-enhancements.css' | asset_url | stylesheet_tag }}

<div class="watch-size-guide-section" style="padding: 60px 0; background: #f8f9fa;">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-10">
        <div class="watch-size-guide-content text-center">
          <h2 class="watch-size-guide-title" style="font-size: 3rem; font-weight: 700; color: #1a1a1a; margin-bottom: 20px;">
            Watch Size Guide
          </h2>
          <p class="watch-size-guide-description" style="font-size: 1.6rem; color: #666; margin-bottom: 50px; max-width: 600px; margin-left: auto; margin-right: auto;">
            Find the perfect watch size for your wrist. Use our comprehensive guide to ensure the best fit and comfort.
          </p>
          
          <div class="watch-size-guide-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-bottom: 50px;">
            
            <!-- Small Watches -->
            <div class="watch-size-card" style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
              <div class="watch-size-icon" style="width: 60px; height: 60px; background: linear-gradient(135deg, #007bff, #0056b3); border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center; color: white; font-size: 24px; font-weight: bold;">
                S
              </div>
              <h3 style="font-size: 2rem; font-weight: 700; color: #1a1a1a; margin-bottom: 15px;">Small (36-38mm)</h3>
              <p style="color: #666; margin-bottom: 20px;">Perfect for smaller wrists or those who prefer a more delicate look.</p>
              <ul style="text-align: left; color: #666; list-style: none; padding: 0;">
                <li style="margin-bottom: 8px;">• Wrist size: 5.5" - 6.5"</li>
                <li style="margin-bottom: 8px;">• Classic and elegant</li>
                <li style="margin-bottom: 8px;">• Suitable for formal wear</li>
              </ul>
            </div>
            
            <!-- Medium Watches -->
            <div class="watch-size-card" style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
              <div class="watch-size-icon" style="width: 60px; height: 60px; background: linear-gradient(135deg, #28a745, #1e7e34); border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center; color: white; font-size: 24px; font-weight: bold;">
                M
              </div>
              <h3 style="font-size: 2rem; font-weight: 700; color: #1a1a1a; margin-bottom: 15px;">Medium (39-42mm)</h3>
              <p style="color: #666; margin-bottom: 20px;">The most versatile size, suitable for most wrist sizes and occasions.</p>
              <ul style="text-align: left; color: #666; list-style: none; padding: 0;">
                <li style="margin-bottom: 8px;">• Wrist size: 6.5" - 7.5"</li>
                <li style="margin-bottom: 8px;">• Universal fit</li>
                <li style="margin-bottom: 8px;">• Great for everyday wear</li>
              </ul>
            </div>
            
            <!-- Large Watches -->
            <div class="watch-size-card" style="background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
              <div class="watch-size-icon" style="width: 60px; height: 60px; background: linear-gradient(135deg, #d4af37, #ffd700); border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center; color: #1a1a1a; font-size: 24px; font-weight: bold;">
                L
              </div>
              <h3 style="font-size: 2rem; font-weight: 700; color: #1a1a1a; margin-bottom: 15px;">Large (43-46mm)</h3>
              <p style="color: #666; margin-bottom: 20px;">Bold and statement-making, perfect for larger wrists or sporty styles.</p>
              <ul style="text-align: left; color: #666; list-style: none; padding: 0;">
                <li style="margin-bottom: 8px;">• Wrist size: 7.5" - 8.5"</li>
                <li style="margin-bottom: 8px;">• Sporty and bold</li>
                <li style="margin-bottom: 8px;">• Great for outdoor activities</li>
              </ul>
            </div>
          </div>
          
          <!-- Measurement Guide -->
          <div class="watch-measurement-guide" style="background: white; padding: 40px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
            <h3 style="font-size: 2.5rem; font-weight: 700; color: #1a1a1a; margin-bottom: 30px;">How to Measure Your Wrist</h3>
            
            <div class="measurement-steps" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px;">
              <div class="measurement-step">
                <div class="step-number" style="width: 40px; height: 40px; background: #1a1a1a; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; margin-bottom: 15px;">1</div>
                <h4 style="font-size: 1.8rem; font-weight: 600; color: #1a1a1a; margin-bottom: 10px;">Wrap a flexible tape measure</h4>
                <p style="color: #666;">Around your wrist just above the wrist bone, where you would normally wear a watch.</p>
              </div>
              
              <div class="measurement-step">
                <div class="step-number" style="width: 40px; height: 40px; background: #1a1a1a; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; margin-bottom: 15px;">2</div>
                <h4 style="font-size: 1.8rem; font-weight: 600; color: #1a1a1a; margin-bottom: 10px;">Note the measurement</h4>
                <p style="color: #666;">Record the measurement in inches or centimeters. This is your wrist circumference.</p>
              </div>
              
              <div class="measurement-step">
                <div class="step-number" style="width: 40px; height: 40px; background: #1a1a1a; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; margin-bottom: 15px;">3</div>
                <h4 style="font-size: 1.8rem; font-weight: 600; color: #1a1a1a; margin-bottom: 10px;">Choose your size</h4>
                <p style="color: #666;">Use our size guide above to find the perfect watch size for your wrist measurement.</p>
              </div>
            </div>
          </div>
          
          <!-- Additional Tips -->
          <div class="watch-tips" style="margin-top: 40px; padding: 30px; background: linear-gradient(135deg, #1a1a1a, #333); border-radius: 12px; color: white;">
            <h3 style="font-size: 2rem; font-weight: 700; margin-bottom: 20px;">Pro Tips</h3>
            <div class="tips-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px;">
              <div class="tip-item">
                <h4 style="font-size: 1.6rem; font-weight: 600; margin-bottom: 10px;">Comfort is Key</h4>
                <p style="color: #ccc;">A watch should feel comfortable and not too tight or loose. You should be able to fit one finger between the strap and your wrist.</p>
              </div>
              <div class="tip-item">
                <h4 style="font-size: 1.6rem; font-weight: 600; margin-bottom: 10px;">Consider the Style</h4>
                <p style="color: #ccc;">Dress watches typically look better smaller, while sports watches can be larger. Consider your lifestyle and preferences.</p>
              </div>
              <div class="tip-item">
                <h4 style="font-size: 1.6rem; font-weight: 600; margin-bottom: 10px;">Try Before You Buy</h4>
                <p style="color: #ccc;">If possible, try on watches in person to get a feel for different sizes and styles before making your purchase.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

