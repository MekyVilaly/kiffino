{
  "name": "Watch Size Guide",
  "tag": "section",
  "class": "watch-size-guide",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Watch Size Guide"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Section Description",
      "default": "Find the perfect watch size for your wrist. Use our comprehensive guide to ensure the best fit and comfort."
    },
    {
      "type": "header",
      "content": "Section Styling"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f8f9fa"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1a1a"
    }
  ],
  "presets": [
    {
      "name": "Watch Size Guide"
    }
  ]
}
{% endschema %}
